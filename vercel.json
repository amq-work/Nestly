{
  "functions": {
    "api/**/*": {
      "includeFiles": "node_modules/.prisma/client/**/*"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/labour",
      "destination": "/labour.html"
    },
    {
      "source": "/labour/(.*)",
      "destination": "/labour.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
